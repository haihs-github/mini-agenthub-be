generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Bảng 1: Người dùng
model User {
  id            Int            @id @default(autoincrement())
  fullname      String         
  phone         String?
  address       String?
  email         String         @unique
  password      String
  permissions   String[]       @default(["CHAT", "CONV_C", "CONV_R", "CONV_U", "CONV_D"]) 
  conversations Conversation[]
  groups        Group[]        @relation("UserGroups") // 1 người thuộc nhiều nhóm 
}

// Bảng 2: Nhóm
model Group {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  permissions String[] @default([])
  users       User[]   @relation("UserGroups") // 1 nhóm có nhiều người 
}

// Bảng 3: Hội thoại (Quản lý các phòng chat)
model Conversation {
  id        Int       @id @default(autoincrement())
  title     String    @default("Cuộc hội thoại mới")
  userId    Int
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[] // Một cuộc hội thoại có nhiều tin nhắn
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// Bảng 4: Tin nhắn (Lưu câu hỏi của User và phản hồi của AI)
model Message {
  id             Int          @id @default(autoincrement())
  role           String       // "user" hoặc "assistant"
  content        String       @db.Text
  modelName      String?
  conversationId Int
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  attachments    Attachment[] // Một tin nhắn có thể kèm nhiều ảnh/file
  createdAt      DateTime     @default(now())
}

// Bảng 5: File phương tiện đính kèm theo từng tin nhắn (Multimodal)
model Attachment {
  id        Int      @id @default(autoincrement())
  filePath  String   // Đường dẫn lưu file trên server (ví dụ: uploads/abc.jpg)
  fileType  String   // Định dạng file (ví dụ: image/jpeg, image/png)
  messageId Int
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}
